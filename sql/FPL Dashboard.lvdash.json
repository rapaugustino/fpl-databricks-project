{
  "datasets": [
    {
      "name": "83e08769",
      "displayName": "Top Twenty Player Stats and Value Rankings Summary",
      "queryLines": [
        "SELECT display_name, team_name, position, current_price,\n",
        "       total_points, points_per_million\n",
        "FROM player_value_rankings\n",
        "LIMIT 20;"
      ],
      "catalog": "fpl_project",
      "schema": "gold"
    },
    {
      "name": "dbfd2c2a",
      "displayName": "Player Performance Metrics By Position Summary",
      "queryLines": [
        "SELECT position,\n",
        "       ROUND(AVG(points_per_million), 2) AS avg_ppm,\n",
        "       COUNT(*) AS player_count\n",
        "FROM player_value_rankings\n",
        "GROUP BY position\n",
        "ORDER BY avg_ppm DESC"
      ],
      "catalog": "fpl_project",
      "schema": "gold"
    }
  ],
